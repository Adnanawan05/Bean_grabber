<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.BeanGrabber" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">#1E1E1E</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">#FFD700</item>
        <item name="colorSecondaryVariant">#FFC107</item>
        <item name="colorOnSecondary">#000000</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Dark mode -->
        <item name="android:windowBackground">#121212</item>
    </style>

    <style name="Widget.BeanGrabber.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@android:color/black</item>
        <item name="backgroundTint">#FFD700</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.BeanGrabber.Button.Grab" parent="Widget.BeanGrabber.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
