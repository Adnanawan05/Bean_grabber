<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".ui.main.MainActivity">

    <!-- Notification Banner -->
    <androidx.cardview.widget.CardView
        android:id="@+id/notificationBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/gold"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/notificationText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/new_beans_bag"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/closeNotification"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Close" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Grip System Panel (Floating Beans Bags) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/gripPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:maxHeight="150dp"
        app:cardBackgroundColor="#2E2E2E"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/notificationBanner">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/active_bags"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/gripRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/noActiveBagsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_active_bags"
                android:textAlignment="center"
                android:textColor="@color/light_gray"
                android:textSize="12sp"
                android:visibility="gone"
                android:padding="16dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Chat RecyclerView (80-90% of screen) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="4dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/gripPanel"
        app:layout_constraintBottom_toTopOf="@id/controlPanel" />

    <!-- Control Panel -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#1E1E1E"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Filter and Options Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/rewardFilterSwitch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/filter_rewards"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/autoClickSwitch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_click"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/accountsButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_manage"
                android:contentDescription="@string/accounts" />

            <ImageView
                android:id="@+id/statisticsButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:contentDescription="@string/statistics" />
        </LinearLayout>

        <!-- Message Input Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:drawable/edit_text"
                android:hint="@string/chat_hint"
                android:textColor="@color/white"
                android:textColorHint="@color/light_gray"
                android:padding="12dp"
                android:maxLines="3"
                android:inputType="textMultiLine|textCapSentences" />

            <Button
                android:id="@+id/sendButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/send"
                style="@style/Widget.BeanGrabber.Button" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
